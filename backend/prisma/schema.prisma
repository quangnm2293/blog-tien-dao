// Blog Tu Tiên - Prisma schema (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(100)
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  createdAt   DateTime  @default(now()) @map("created_at")
  articles    Article[]

  @@map("categories")
}

model Novel {
  id          String    @id @default(uuid())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  description String?   @db.Text
  coverImage  String?   @map("cover_image") @db.VarChar(500)
  authorName  String?   @map("author_name") @db.VarChar(255)
  status      String    @default("completed") @db.VarChar(50)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  characters  Character[]
  articles    Article[]

  @@map("novels")
}

model Character {
  id          String   @id @default(uuid())
  novelId     String   @map("novel_id")
  name        String   @db.VarChar(255)
  slug        String   @db.VarChar(255)
  description String?  @db.Text
  powerRank   Int?     @map("power_rank")
  avatarUrl   String?   @map("avatar_url") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  articles    Article[]

  @@unique([novelId, slug])
  @@map("characters")
}

model Article {
  id              String    @id @default(uuid())
  title           String    @db.VarChar(500)
  slug            String    @db.VarChar(500)
  content         String    @db.Text
  excerpt         String?   @db.Text
  categoryId      String    @map("category_id")
  novelId         String?   @map("novel_id")
  characterId     String?   @map("character_id")
  metaTitle       String?   @map("meta_title") @db.VarChar(70)
  metaDescription String?   @map("meta_description") @db.VarChar(160)
  featuredImage   String?   @map("featured_image") @db.VarChar(500)
  viewCount       Int       @default(0) @map("view_count")
  published       Boolean   @default(true)
  publishedAt     DateTime  @default(now()) @map("published_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  category        Category  @relation(fields: [categoryId], references: [id])
  novel           Novel?    @relation(fields: [novelId], references: [id], onDelete: SetNull)
  character       Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  relatedFrom     ArticleRelated[] @relation("ArticleToRelated")
  relatedTo       ArticleRelated[] @relation("ArticleRelatedTo")

  @@unique([slug, categoryId])
  @@map("articles")
}

model ArticleRelated {
  articleId        String @map("article_id")
  relatedArticleId String @map("related_article_id")
  sortOrder        Int    @default(0) @map("sort_order")
  article          Article @relation("ArticleToRelated", fields: [articleId], references: [id], onDelete: Cascade)
  relatedArticle   Article @relation("ArticleRelatedTo", fields: [relatedArticleId], references: [id], onDelete: Cascade)

  @@id([articleId, relatedArticleId])
  @@map("article_related")
}

model AdSlot {
  id        String   @id @default(uuid())
  name      String   @db.VarChar(100)
  slotId    String?  @map("slot_id") @db.VarChar(100)
  position  String   @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ad_slots")
}
